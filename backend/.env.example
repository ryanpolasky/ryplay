LASTFM_API_KEY=your_api_key_here
# Optional: Spotify client credentials for fallback artist/track images
# Create a free app at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# Optional: Spotify user-OAuth redirect URI (only needed for the disabled
# Spotify Lite Mode flow)
SPOTIFY_REDIRECT_URI=
# Optional: comma-separated CORS allowlist. Default is "*" (any origin).
# Recommended in production: e.g. "https://ryplay.dev,http://localhost:5173"
RYPLAY_ALLOWED_ORIGINS=*
